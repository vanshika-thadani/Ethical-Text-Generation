# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
venv/
.env
.env.*

# Evaluation results (generated at runtime — not source code)
results/evaluation_results.csv
results/summary.json

# Uploaded documents (transient — not source code)
uploads/*
!uploads/README.md

# ChromaDB vector store (rebuilt from uploads — not source code)
vectordb/*
!vectordb/README.md

# Test cache
.pytest_cache/

# Editor / IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# HuggingFace model cache (large, downloaded automatically)
.cache/
